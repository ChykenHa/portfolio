@page
@model IndexModel
@{
    ViewData["Title"] = "Home";
}

<main>
    <!-- Hero Section -->
    <section id="hero" class="hero-section">
        <div class="container hero-container">
            <div class="hero-content">
                <div class="badge-glow fade-in-up">
                    <span class="badge-text"><i class="fa-solid fa-code-fork"></i> Backend & DevOps Engineer</span>
                </div>
                <h1 class="hero-title fade-in-up delay-1">
                    Hi, I am <br>
                    <span class="gradient-text text-glow">Le Phung Ha</span>
                </h1>
                <p class="hero-subtitle fade-in-up delay-2">
                    Software Engineering student at Duy Tan University. Specializing in <strong>C# & ASP.NET Core</strong>, building resilient backends, database architectures, and integrating Artificial Intelligence (AI/NLP) solutions.
                </p>
                <div class="hero-actions fade-in-up delay-3">
                    <a href="#projects" class="btn btn-primary btn-glow">Explore Projects</a>
                    <a href="#contact" class="btn btn-secondary">Get In Touch</a>
                </div>
                
                <div class="hero-stats fade-in-up delay-4">
                    <div class="stat-item">
                        <span class="stat-num">3+</span>
                        <span class="stat-lbl">Months Interning</span>
                    </div>
                    <div class="stat-item">
                        <span class="stat-num">11+</span>
                        <span class="stat-lbl">GitHub Repos</span>
                    </div>
                    <div class="stat-item">
                        <span class="stat-num">3.25</span>
                        <span class="stat-lbl">University GPA</span>
                    </div>
                </div>
            </div>
            
            <div class="hero-visual fade-in-up delay-2">
                <div class="ocean-sphere-wrapper">
                    <div class="ocean-sphere">
                        <div class="wave wave-1"></div>
                        <div class="wave wave-2"></div>
                        <div class="wave wave-3"></div>
                        <div class="sphere-core">
                            <i class="fa-solid fa-terminal sphere-icon"></i>
                        </div>
                    </div>
                    <div class="floating-tech tech-csharp" title="C#"><span class="font-tech">C#</span></div>
                    <div class="floating-tech tech-dotnet" title=".NET"><i class="fa-solid fa-cubes"></i></div>
                    <div class="floating-tech tech-docker" title="Docker"><i class="fa-brands fa-docker"></i></div>
                    <div class="floating-tech tech-database" title="SQL Server"><i class="fa-solid fa-database"></i></div>
                </div>
            </div>
        </div>
        
        <a href="#about" class="scroll-indicator" aria-label="Scroll Down">
            <span class="mouse">
                <span class="wheel"></span>
            </span>
            <span class="arrow-scroll"></span>
        </a>
    </section>

    <!-- About Me Section -->
    <section id="about" class="about-section section-padding">
        <div class="container">
            <div class="section-header scroll-reveal">
                <span class="section-tag">About Me</span>
                <h2 class="section-title">My Journey & Ambitions</h2>
                <div class="section-line"></div>
            </div>
            
            <div class="about-grid">
                <div class="about-image-card scroll-reveal">
                    <div class="avatar-glow-wrapper">
                        <div class="avatar-bg"></div>
                        <div class="avatar-fallback">
                            <img src="~/images/avatar.jpg" alt="Le Phung Ha" class="avatar-img" />
                        </div>
                    </div>
                    
                    <div class="fun-fact-box">
                        <h4 class="fun-fact-title"><i class="fa-solid fa-wand-magic-sparkles text-glow"></i> Outside the Code</h4>
                        <p class="fun-fact-text">
                            When I'm not coding, I collect Mecha action figures, set up freshwater aquariums, or jump into tactical Valorant matches with my team!
                        </p>
                    </div>
                </div>
                
                <div class="about-info-content scroll-reveal delay-1">
                    <h3 class="about-greeting">Architecting Optimal and Reliable Systems</h3>
                    <p class="about-bio">
                        I am currently pursuing a Bachelor's in Software Engineering (2023 - 2027) at Duy Tan University. Aspiring to build a career as a professional <strong>C# / Backend Developer</strong>, I actively research web architecture, efficient DevOps pipelines, and smart applications incorporating Natural Language Processing (NLP).
                    </p>
                    
                    <div class="education-card">
                        <div class="edu-icon"><i class="fa-solid fa-graduation-cap"></i></div>
                        <div class="edu-details">
                            <span class="edu-year">2023 - 2027</span>
                            <h4 class="edu-school">Duy Tan University (DTU)</h4>
                            <p class="edu-degree">Software Engineer | GPA: 3.25 / 4.0</p>
                            <ul class="edu-coursework">
                                <li><i class="fa-solid fa-circle-check"></i> Data Structures & Algorithms</li>
                                <li><i class="fa-solid fa-circle-check"></i> Database Systems (SQL/NoSQL)</li>
                                <li><i class="fa-solid fa-circle-check"></i> Modern Web Development</li>
                            </ul>
                        </div>
                    </div>

                    <div class="experience-card">
                        <div class="exp-icon"><i class="fa-solid fa-briefcase"></i></div>
                        <div class="exp-details">
                            <span class="exp-year">Feb 2026 - May 2026 (3 Months)</span>
                            <h4 class="exp-school">DevOps Engineer Intern</h4>
                            <p class="edu-degree">Wisdom Brain</p>
                            <ul class="edu-coursework">
                                <li><i class="fa-solid fa-circle-check"></i> Configured containerized services with Docker & Kubernetes.</li>
                                <li><i class="fa-solid fa-circle-check"></i> Built and optimized automated CI/CD deployment pipelines.</li>
                                <li><i class="fa-solid fa-circle-check"></i> Managed server environments, Linux networking, and system logs.</li>
                            </ul>
                        </div>
                    </div>
                    
                    <div class="languages-box">
                        <div class="lang-item">
                            <span class="lang-title"><i class="fa-solid fa-earth-americas"></i> English Proficiency</span>
                            <span class="lang-val">IELTS 6.5</span>
                        </div>
                        <div class="lang-item">
                            <span class="lang-title"><i class="fa-solid fa-award"></i> TOEIC Certifications</span>
                            <span class="lang-val">2026 Professional</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Research Spotlight Section -->
    <section id="research" class="research-section section-padding waves-bg">
        <div class="container">
            <div class="section-header scroll-reveal">
                <span class="section-tag">Research Spotlight</span>
                <h2 class="section-title">AI & Health Social Network</h2>
                <div class="section-line"></div>
            </div>
            
            <div class="spotlight-card scroll-reveal">
                <div class="spotlight-badge">
                    <i class="fa-solid fa-trophy"></i> @Model.MindConnect.Award
                </div>
                
                <div class="spotlight-grid">
                    <div class="spotlight-text-content">
                        <span class="project-meta">Independent Research & Development</span>
                        <h3 class="spotlight-title">@Model.MindConnect.Name</h3>
                        <p class="spotlight-description">
                            @Model.MindConnect.Description
                        </p>
                        
                        <div class="spotlight-features">
                            <div class="feature-item">
                                <span class="f-icon"><i class="fa-solid fa-brain"></i></span>
                                <div class="f-text">
                                    <h5>Vietnamese NLP Classifier</h5>
                                    <p>Trained localized Python text-classification models to recognize markers of depression.</p>
                                </div>
                            </div>
                            <div class="feature-item">
                                <span class="f-icon"><i class="fa-solid fa-network-wired"></i></span>
                                <div class="f-text">
                                    <h5>Cross-Platform Backend</h5>
                                    <p>Configured unified ASP.NET Core APIs to serve Razor web views and React Native clients simultaneously.</p>
                                </div>
                            </div>
                            <div class="feature-item">
                                <span class="f-icon"><i class="fa-solid fa-robot"></i></span>
                                <div class="f-text">
                                    <h5>Hybrid LLM Support</h5>
                                    <p>Integrated GPT and Gemini engines for chatbot support, mental health advice, and real-time guidance.</p>
                                </div>
                            </div>
                        </div>
                        
                        <div class="tech-tags">
                            @foreach (var tag in Model.MindConnect.TechTags)
                            {
                                <span class="tag">@tag</span>
                            }
                        </div>
                        
                        <div class="spotlight-links">
                            <a href="@Model.MindConnect.DemoUrl" target="_blank" class="btn btn-primary btn-sm"><i class="fa-solid fa-globe"></i> Live Web Demo</a>
                            <a href="@Model.MindConnect.GithubUrl" target="_blank" class="btn btn-secondary btn-sm"><i class="fa-brands fa-github"></i> Explore Source Code</a>
                        </div>
                    </div>
                    
                    <div class="spotlight-visual">
                        <div class="glass-device">
                            <div class="device-header">
                                <span class="dot red"></span>
                                <span class="dot yellow"></span>
                                <span class="dot green"></span>
                                <span class="device-title">mindconnect.io</span>
                            </div>
                            <div class="device-body">
                                <div class="mockup-chart-container">
                                    <div class="mockup-header-ui">
                                        <span class="avatar-mini"></span>
                                        <span class="text-line-mini"></span>
                                    </div>
                                    <div class="mockup-post">
                                        <p class="mockup-post-txt">Feeling extremely overwhelmed with work lately...</p>
                                        <span class="sentiment-indicator indicator-red animate-pulse">Depression Signal Detected</span>
                                    </div>
                                    <div class="mockup-ai-chat">
                                        <div class="chat-bubble user">How can I manage stress better during finals?</div>
                                        <div class="chat-bubble ai">
                                            <span class="ai-spark"><i class="fa-solid fa-wand-magic-sparkles"></i> AI Companion:</span> Try applying the Pomodoro technique and taking 5-minute walks to reset...
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Projects Section -->
    <section id="projects" class="projects-section section-padding">
        <div class="container">
            <div class="section-header scroll-reveal">
                <span class="section-tag">My Creations</span>
                <h2 class="section-title">Selected Projects</h2>
                <div class="section-line"></div>
            </div>
            
            <!-- Project Filter Control -->
            <div class="project-filters scroll-reveal">
                <button class="filter-btn active" data-filter="all">All</button>
                <button class="filter-btn" data-filter="web">Web & Backend</button>
                <button class="filter-btn" data-filter="mobile">Mobile App</button>
                <button class="filter-btn" data-filter="other">Desktop & Desktop</button>
            </div>
            
            <!-- Projects Grid -->
            <div class="projects-grid">
                @foreach (var project in Model.Projects)
                {
                    <div class="project-card scroll-reveal" data-category="@project.Category">
                        <div class="project-card-visual @project.VisualClass">
                            <i class="@project.IconClass project-icon"></i>
                        </div>
                        <div class="project-card-body">
                            <div class="project-role">
                                @if (project.Role.Contains("Leader"))
                                {
                                    <i class="fa-solid fa-crown text-glow"></i>
                                }
                                else
                                {
                                    <i class="fa-solid fa-user-gear"></i>
                                }
                                @project.Role
                            </div>
                            <h3 class="project-name">@project.Name</h3>
                            <p class="project-desc">@project.Description</p>
                            <div class="project-tech">
                                @foreach (var tag in project.TechTags)
                                {
                                    <span>@tag</span>
                                }
                            </div>
                            <div class="project-footer">
                                <a href="@project.GithubUrl" target="_blank" class="project-link"><i class="fa-brands fa-github"></i> Repository <i class="fa-solid fa-arrow-up-right-from-square"></i></a>
                                @if (!string.IsNullOrEmpty(project.DemoUrl))
                                {
                                    <a href="@project.DemoUrl" target="_blank" class="project-link" style="margin-left: 15px;"><i class="fa-brands fa-github"></i> Sub-Repository <i class="fa-solid fa-arrow-up-right-from-square"></i></a>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </section>

    <!-- Skills Section -->
    <section id="skills" class="skills-section section-padding waves-bg-inverted">
        <div class="container">
            <div class="section-header scroll-reveal">
                <span class="section-tag">Technical Competencies</span>
                <h2 class="section-title">My Toolbox</h2>
                <div class="section-line"></div>
            </div>
            
            <div class="skills-grid">
                <!-- Column 1: Languages -->
                <div class="skill-category-card scroll-reveal">
                    <h3 class="category-title"><i class="fa-solid fa-code"></i> Languages</h3>
                    <div class="skill-list">
                        <div class="skill-item">
                            <div class="skill-info">
                                <span class="skill-name">C# (.NET)</span>
                                <span class="skill-percentage">Core Stack</span>
                            </div>
                            <div class="skill-bar"><div class="skill-progress-bar" data-width="85%"></div></div>
                        </div>
                        <div class="skill-item">
                            <div class="skill-info">
                                <span class="skill-name">Java & Kotlin</span>
                                <span class="skill-percentage">Proficient</span>
                            </div>
                            <div class="skill-bar"><div class="skill-progress-bar" data-width="75%"></div></div>
                        </div>
                        <div class="skill-item">
                            <div class="skill-info">
                                <span class="skill-name">SQL</span>
                                <span class="skill-percentage">Proficient</span>
                            </div>
                            <div class="skill-bar"><div class="skill-progress-bar" data-width="80%"></div></div>
                        </div>
                        <div class="skill-item">
                            <div class="skill-info">
                                <span class="skill-name">Python & JavaScript</span>
                                <span class="skill-percentage">Core & AI</span>
                            </div>
                            <div class="skill-bar"><div class="skill-progress-bar" data-width="70%"></div></div>
                        </div>
                    </div>
                </div>
                
                <!-- Column 2: Frameworks & Web -->
                <div class="skill-category-card scroll-reveal delay-1">
                    <h3 class="category-title"><i class="fa-solid fa-cubes"></i> Frameworks</h3>
                    <div class="skill-list">
                        <div class="skill-item">
                            <div class="skill-info">
                                <span class="skill-name">ASP.NET Core (Web/API)</span>
                                <span class="skill-percentage">Core Stack</span>
                            </div>
                            <div class="skill-bar"><div class="skill-progress-bar" data-width="85%"></div></div>
                        </div>
                        <div class="skill-item">
                            <div class="skill-info">
                                <span class="skill-name">Entity Framework Core</span>
                                <span class="skill-percentage">Proficient</span>
                            </div>
                            <div class="skill-bar"><div class="skill-progress-bar" data-width="80%"></div></div>
                        </div>
                        <div class="skill-item">
                            <div class="skill-info">
                                <span class="skill-name">React Native (Mobile)</span>
                                <span class="skill-percentage">Familiar</span>
                            </div>
                            <div class="skill-bar"><div class="skill-progress-bar" data-width="60%"></div></div>
                        </div>
                        <div class="skill-item">
                            <div class="skill-info">
                                <span class="skill-name">Razor Pages / HTML & CSS</span>
                                <span class="skill-percentage">Proficient</span>
                            </div>
                            <div class="skill-bar"><div class="skill-progress-bar" data-width="75%"></div></div>
                        </div>
                    </div>
                </div>
                
                <!-- Column 3: DB & DevOps -->
                <div class="skill-category-card scroll-reveal delay-2">
                    <h3 class="category-title"><i class="fa-solid fa-gears"></i> Systems & DevOps</h3>
                    <div class="skill-list">
                        <div class="skill-item">
                            <div class="skill-info">
                                <span class="skill-name">SQL Server</span>
                                <span class="skill-percentage">Core Stack</span>
                            </div>
                            <div class="skill-bar"><div class="skill-progress-bar" data-width="85%"></div></div>
                        </div>
                        <div class="skill-item">
                            <div class="skill-info">
                                <span class="skill-name">MongoDB & PostgreSQL</span>
                                <span class="skill-percentage">Familiar</span>
                            </div>
                            <div class="skill-bar"><div class="skill-progress-bar" data-width="65%"></div></div>
                        </div>
                        <div class="skill-item">
                            <div class="skill-info">
                                <span class="skill-name">Docker & Kubernetes</span>
                                <span class="skill-percentage">Learning</span>
                            </div>
                            <div class="skill-bar"><div class="skill-progress-bar" data-width="60%"></div></div>
                        </div>
                        <div class="skill-item">
                            <div class="skill-info">
                                <span class="skill-name">Git & CI-CD Pipelines</span>
                                <span class="skill-percentage">Proficient</span>
                            </div>
                            <div class="skill-bar"><div class="skill-progress-bar" data-width="80%"></div></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Contact Section -->
    <section id="contact" class="contact-section section-padding">
        <div class="container">
            <div class="section-header scroll-reveal">
                <span class="section-tag">Contact</span>
                <h2 class="section-title">Let's Build Something Together</h2>
                <div class="section-line"></div>
            </div>
            
            <div class="contact-grid">
                <!-- Info details -->
                <div class="contact-info scroll-reveal">
                    <h3 class="info-title">Let's discuss your next project!</h3>
                    <p class="info-text">
                        I am currently open to internship positions, backend developer roles, or project collaborations. Reach out and I will reply within 24 hours.
                    </p>
                    
                    <div class="info-list">
                        <div class="info-link-card">
                            <span class="info-icon"><i class="fa-solid fa-phone"></i></span>
                            <div class="info-card-text">
                                <span>Phone Number</span>
                                <a href="tel:0347372061">034 737 2061</a>
                            </div>
                        </div>
                        
                        <div class="info-link-card">
                            <span class="info-icon"><i class="fa-solid fa-envelope"></i></span>
                            <div class="info-card-text">
                                <span>Email Address</span>
                                <a href="mailto:lephungha1203@gmail.com">lephungha1203@gmail.com</a>
                            </div>
                        </div>
                        
                        <div class="info-link-card">
                            <span class="info-icon"><i class="fa-solid fa-location-dot"></i></span>
                            <div class="info-card-text">
                                <span>Location</span>
                                <p>Hoa Khanh Nam, Da Nang, Vietnam</p>
                            </div>
                        </div>
                    </div>
                    
                    <div class="social-links-box">
                        <a href="https://github.com/ChykenHa" target="_blank" class="social-icon" aria-label="GitHub"><i class="fa-brands fa-github"></i></a>
                        <a href="https://www.linkedin.com/in/h%C3%A0-l%C3%AA-ph%C3%B9ng-24110137b/" target="_blank" class="social-icon" aria-label="LinkedIn"><i class="fa-brands fa-linkedin-in"></i></a>
                        <a href="mailto:lephungha1203@gmail.com" class="social-icon" aria-label="Email"><i class="fa-solid fa-envelope"></i></a>
                    </div>
                </div>
                
                <!-- Contact Form -->
                <div class="contact-form-container scroll-reveal delay-1">
                    <form id="portfolio-contact-form" class="glass-form">
                        <div class="form-row">
                            <div class="form-group">
                                <label for="name">Your Name</label>
                                <input type="text" id="name" name="name" required placeholder="John Doe">
                            </div>
                            <div class="form-group">
                                <label for="email">Email Address</label>
                                <input type="email" id="email" name="email" required placeholder="john@example.com">
                            </div>
                        </div>
                        
                        <div class="form-group">
                            <label for="subject">Subject</label>
                            <input type="text" id="subject" name="subject" required placeholder="Project Opportunity / Questions">
                        </div>
                        
                        <div class="form-group">
                            <label for="message">Message</label>
                            <textarea id="message" name="message" rows="5" required placeholder="Tell me about your project..."></textarea>
                        </div>
                        
                        <button type="submit" class="btn btn-primary btn-submit btn-glow">
                            <span>Send Message <i class="fa-solid fa-paper-plane"></i></span>
                        </button>
                        
                        <div class="form-feedback-message"></div>
                    </form>
                </div>
            </div>
        </div>
    </section>
</main>
